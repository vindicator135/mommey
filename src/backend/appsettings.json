{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Mcp": {
    "Notion": {
      "Command": "npx",
      "Arguments": [
        "-y",
        "@modelcontextprotocol/server-notion"
      ],
      "Env": {
        "NOTION_API_KEY": "YOUR_NOTION_API_KEY_HERE"
      }
    },
    "Google": {
      "Command": "npx",
      "Arguments": [
        "-y",
        "@modelcontextprotocol/server-google-calendar"
      ],
      "Env": {
        "GOOGLE_CALENDAR_CREDENTIALS": "YOUR_GOOGLE_CREDENTIALS_HERE"
      }
    }
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY_HERE",
    "ModelId": "gpt-4o-mini"
  }
}