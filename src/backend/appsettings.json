{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Mcp": {
    "Notion": {
      "Command": "npx",
      "Arguments": [
        "-y",
        "@modelcontextprotocol/server-notion"
      ],
      "Env": {
        "NOTION_API_KEY": "YOUR_NOTION_API_KEY_HERE",
        "NO_UPDATE_NOTIFIER": "1",
        "npm_config_loglevel": "silent"
      }
    },
    "Google": {
      "Command": "node",
      "Arguments": [
        "Mcp/mcp-google-calendar-proxy.js"
      ],
      "Env": {
        "NO_UPDATE_NOTIFIER": "1",
        "npm_config_loglevel": "silent",
        "CREDENTIALS_PATH": "credentials.json",
        "TOKEN_PATH": "mcp-google-calendar-token.json"
      }
    },
    "Filesystem": {
      "Command": "npx",
      "Arguments": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "Env": {
        "NO_UPDATE_NOTIFIER": "1",
        "npm_config_loglevel": "silent"
      }
    }
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY_HERE",
    "ModelId": "gpt-4o-mini"
  }
}